# ORDI environment variables. Copy to .env and fill in.
#   cp .env.sample .env
# .env is gitignored; .env.sample is tracked. main.py loads .env at startup.

# NASA FIRMS map key for active-fire tasking requests (task_source="fire").
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Root of the cloned MobiCom24 SatelliteCOTS dataset (BUPT-1 telemetry + Atlas
# 200DK measurements). Clone from:
#   https://github.com/TiansuanConstellation/MobiCom24-SatelliteCOTS
# Unzip CommonData-Telemetries/telemetry_all.csv.zip after cloning.
MOBICOM24_COTS_ROOT=

# Optional: directory for regenerable real-pipeline caches (CelesTrak TLEs,
# Sentinel-2 STAC, FIRMS fires, reduced telemetry). Defaults to ./data.
# ORDI_DATA_DIR=data
